# .env.example — copy to .env and fill in real values. NEVER commit .env (L3).

# Kalshi environment — 'demo' for paper trading, 'prod' for real money (L8).
# Changing this one value is all that's needed to switch environments; the matching
# credential pair below is selected automatically.
KALSHI_ENV=demo

# Kalshi credentials — keep BOTH sets here so switching KALSHI_ENV is the only change needed.
# Get these from https://kalshi.com/account/api  (demo and prod accounts are separate)
KALSHI_DEMO_API_KEY=your_kalshi_demo_key_id
KALSHI_DEMO_API_SECRET=your_kalshi_demo_rsa_private_key_pem_or_path
KALSHI_PROD_API_KEY=your_kalshi_prod_key_id
KALSHI_PROD_API_SECRET=your_kalshi_prod_rsa_private_key_pem_or_path

# Other API Keys
API_FOOTBALL_KEY=your_api_football_key
THE_ODDS_API_KEY=your_odds_api_key

# Live probability engine — 'dc' (Dixon-Coles goals model + ELO strength prior,
# validated out-of-sample, the default) or 'classifier' (original logistic/XGBoost
# bundle). Set MODEL_ENGINE=classifier to roll back instantly.
MODEL_ENGINE=dc

# Weight of squad strength (top-11 player ratings) blended into the DC ELO prior at fit
# time, relative to ELO. Lets star-laden squads lift their own attack/defense prior.
# DC engine only; unvalidated on history (no past squad data) so keep it modest. 0 = off.
DC_SQUAD_PRIOR_WEIGHT=0.5

# Strategy parameters
MIN_EDGE_THRESHOLD=0.04
MAX_BET_FRACTION=0.05
MAX_PORTFOLIO_EXPOSURE=0.20
KELLY_FRACTION=0.5
STOP_LOSS_THRESHOLD=0.25

# Bankroll
INITIAL_BANKROLL_CENTS=20000

# Database
DB_PATH=data/db.sqlite

# Logging
LOG_LEVEL=INFO
